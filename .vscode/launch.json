{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}"
        }, {            
            "type": "msedge",
            "request": "launch",
            "name": "Launch MS Edge against localhost",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}"
        }, {                       
            "type": "firefox",
            "request": "launch",
            "name": "Launch FF against localhost",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}",
            "tmpDir": "${workspaceFolder}/.tmp/"
        }
    ]
}