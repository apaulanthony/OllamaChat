		"dev": "vite dev",
		"preview": "vite preview",
		"generate-icons": "node generate-icons.mjs"
	},
	"devDependencies": {
		"dompurify": "^3.3.3",
		"katex": "^0.16.45",
		"marked": "^18.0.0",
		"mermaid": "^11.14.0",
		"sass": "^1.99.0",
		"sharp": "^0.34.5",
		"vite": "^8.0.4"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
