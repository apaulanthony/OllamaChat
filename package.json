{
	"name": "ollamachat",
	"version": "1.3.0",
	"description": "Chatbot interface for locally hosted LLMs (like Ollama or LM Studio)",
	"license": "ISC",
	"author": "A Paul Anthony",
	"type": "module",
	"main": "index.html",
	"config": {
		"baseUrl": "http://localhost:1234/api/v1/",
		"model": "llama3",
